<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leandro Heffes</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="/js/mobileNavbar.js" defer></script>
</head>
<body>
    <header>
        <nav class="headerNavbar">
            <ul>
                <li><a href="">Home</a></li>
                <li><a href="">Proyects</a></li>
                <li><a href="">About me</a></li>
                <li><a href="">Contact</a></li>
            </ul>
        </nav>

        <button class="mobileNavbarButton">
            <i class="fa-solid fa-bars-staggered"></i>
        </button>
    </header>

    <main>
        <nav class="mobileNavbar">
            <ul class="mobileNavbarUnorderList">
                <li><a class="mobileNavbarLink" id="mobileNavbarLink1" href="#homeSection">Home</a></li>
                <li><a class="mobileNavbarLink" id="mobileNavbarLink2" href="#proyectsSection">Proyects</a></li>
                <li><a class="mobileNavbarLink" id="mobileNavbarLink3" href="#aboutMeSection">About me</a></li>
                <li><a class="mobileNavbarLink" id="mobileNavbarLink4" href="#contactSection">Contact</a></li>
            </ul>

            <button class="closeMobileNavbarButton">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </nav>

        <section class="homeSection" id="homeSection">
            <div class="homeInformation">
                <h1 class="homeTItle">Leandro Heffes</h1>
                <h2 class="homeSubtitle">Full Stack Web Developer</h2>
                <button class="cvButton">
                    <a class="cvLink" download="CV Leandro Heffes.pdf" href="/pdf/CV Leandro Heffes.pdf">Download my CV</a>
                </button>
            </div>
        </section>

        <section class="proyectsSection" id="proyectsSection">
            <h3 class="sectionTitle">Proyects</h3>

            <div class="proyectsContainer">
                <div class="proyectContainer">
                    <img class="proyectImage" src="/img/sw-mockup.webp" alt="SW Asistencia Virtual mockup">
                    <h4 class="proyectTitle">SW Asistencia Virtual</h4>

                    <div class="proyectDetail" id="swProyectDetail">
                        <img class="proyectImageDetail" src="/img/sw-mockup.webp" alt="SW Asistencia Virtual mockup">
                        <h4 class="proyectTitleDetail">SW Asistencia Virtual</h4>

                        <div class="proyectLinks">
                            <a class="proyectLink" href="https://github.com/leandroheffes24/sw-asistencia-virtual"><i class="fa-brands fa-github"></i></a>
                            <a class="proyectLink" href="https://sw-asistencia-virtual.vercel.app/"><i class="fa-solid fa-arrow-up-right-from-square"></i></a>
                        </div>
                    </div>
                </div>

                <div class="proyectContainer">
                    <img class="proyectImage" src="/img/ecommerce-mockup.webp" alt="Clothing e-commerce mockup">
                    <h4 class="proyectTitle">Clothing e-commerce</h4>
                </div>
            </div>
        </section>

        <section class="aboutMeSection" id="aboutMeSection">
            <h3 class="sectionTitle">About me</h3>

            <div class="aboutMeContainer">
                <div class="aboutMeImageAndInfoContainer">
                    <img class="aboutMeImage" src="/img/Leandro-Heffes.png" alt="Leandro Heffes picture">
                    <div class="aboutMeInfoContainer">
                        <p>I'm Leandro Heffes, I'm 21 years old and I'm from Argentina. I actually live in Bahía Blanca, Buenos Aires, and I'm working as a freelance full stack web developer.</p>
                    </div>
                </div>

                <div class="aboutMeCardsContainer">
                    <div class="aboutMeCertificateCard aboutMeCard">
                        <i class="fa-solid fa-medal aboutMeCardIcon"></i>
                        <p class="aboutMeCardInfo">Certificate in full stack web development</p>
                    </div>

                    <div class="aboutMeExperienceCard aboutMeCard">
                        <i class="fa-solid fa-flask aboutMeCardIcon"></i>
                        <p class="aboutMeCardInfo">+1 year of experience</p>
                    </div>

                    <div class="aboutMeSatisfiedCustomersCard aboutMeCard">
                        <i class="fa-solid fa-face-smile-beam aboutMeCardIcon"></i>
                        <p class="aboutMeCardInfo">100% satisfied customers</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="contactSection" id="contactSection">
            <h3 class="sectionTitle">Contact me</h3>

            <div class="contactFormContainer">
                <form class="contactForm" action="">
                    <input class="formInput" type="text" name="name" placeholder="Name">
                    <input class="formInput" type="email" name="email" placeholder="Email">
                    <textarea class="formInput" name="message" id="message" cols="30" rows="7" placeholder="Your message"></textarea>
                    <button class="contactFormSubmitButton" type="submit">Submit</button>
                </form>
            </div>
        </section>
    </main>

    <footer>
        <div class="footerInfoContainer">
            <p class="footerCopyright">© Leandro Heffes 2024. All rights reserved.</p>
            <p class="footerPortfolioLink">Developed by <a class="portfolioLink" href="https://leandroheffes.vercel.app">Leandro Heffes</a></p>
        </div>
    </footer>
</body>
</html>