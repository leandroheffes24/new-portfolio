                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M18 6l-12 12" />
                    <path d="M6 6l12 12" />
                </svg>
            </div>

            <ul class="headerNavbarList">
                <li class="headerNavbarItemList"><a class="headerNavbarItemListLink" href="#home">HOME</a></li>
                <li class="headerNavbarItemList"><a class="headerNavbarItemListLink" href="#sobreMi">SOBRE MÍ</a></li>
                <li class="headerNavbarItemList"><a class="headerNavbarItemListLink" href="#experienciaProfesional">EXPERIENCIA PROFESIONAL</a></li>
                <li class="headerNavbarItemList"><a class="headerNavbarItemListLink" href="#proyectos">PROYECTOS</a></li>
                <li class="headerNavbarItemList"><a class="headerNavbarItemListLink" href="#educacion">EDUCACIÓN</a></li>
                <li class="headerNavbarItemList"><a class="headerNavbarItemListLink" href="#tecnologias">TECNOLOGÍAS</a></li>
                <li class="headerNavbarItemList"><a class="headerNavbarItemListLink" href="#contacto">CONTACTO</a></li>
            </ul>
        </nav>
    </header>

    <main>
        <section class="homeSection">
            <section class="homeLeftSection">

            </section>

            <section class="homeRightSection">

            </section>
        </section>
    </main>
