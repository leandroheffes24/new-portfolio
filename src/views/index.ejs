<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leandro Heffes</title>
    <link rel="stylesheet" href="/css/styles.css">
    <script src="/js/headerNavbarScript.js" defer></script>
    <script src="/js/headerLanguageScript.js" defer></script>
</head>
<body>
    <header>
        <div class="headerTitleContainer">
            <a href="/"><h1 class="headerTitle">Leandro Heffes</h1></a>
        </div>

        <div class="headerLanguageAndMenuIconContainer">
            <div class="headerLanguageContainer">
                <div class="headerSelectedLanguageContainer">
                    <img id="headerSelectedLanguage" class="headerSelectedLanguage" src="/images/english.webp" alt="English language">
                </div>
    
                <div id="headerLanguagesContainer" class="headerLanguagesContainer">
                    <img id="headerEnglishLanguage" class="headerLanguage" src="/images/english.webp" alt="English language">
                    <img id="headerSpanishLanguage" class="headerLanguage" src="/images/spanish.webp" alt="Spanish language">
                </div>
            </div>
    
            <div class="headerOpenMenuIconContainer">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="headerOpenMenuIcon">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M4 8l16 0"/>
                    <path d="M4 16l16 0"/>
                </svg>
            </div>
        </div>

        <nav class="headerNavbar">
